# Frontend — copy to .env.local. NEXT_PUBLIC_* are exposed to the browser.

# Flare
# NEXT_PUBLIC_FLARE_RPC_URL=https://flare-api.flare.network/ext/bc/C/rpc
# NEXT_PUBLIC_FLARE_CHAIN_ID=14

# Contract addresses (from Person B after deployment)
# NEXT_PUBLIC_PAYOUT_CONTRACT_ADDRESS=
# NEXT_PUBLIC_YIELD_CONTRACT_ADDRESS=

# Optional: activity index or API for map (if provided by Person A)
# NEXT_PUBLIC_ACTIVITY_INDEX_URL=

# WalletConnect / project id (if used)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
