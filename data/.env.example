# Data layer — copy to .env and fill. No secrets in repo.

# Overpass (OSM)
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# Mapbox (free tier)
# MAPBOX_ACCESS_TOKEN=

# Reddit API
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=

# Event APIs (e.g. Ticketmaster, PredictHQ — open/free tier)
# EVENT_API_KEY=
# EVENT_API_BASE_URL=

# Storage
# DATA_STORAGE_PATH=./storage/data
# ACTIVITY_INDEX_OUTPUT_PATH=./storage/activity_index_output.json

# Optional: FDC or frontend callback (if you push from here)
# FDC_SUBMIT_URL=
# FRONTEND_API_URL=
